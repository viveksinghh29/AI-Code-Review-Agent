# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage

# ── Git ──────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store

# ── Runtime data ─────────────────────────────────────────────────────────────
/tmp/ai_code_review_repos/
reports/*.json
reports/*.md
*.db
*.db-shm
*.db-wal

# ── Docs ─────────────────────────────────────────────────────────────────────
*.md
docs/

# ── Tests (not needed in production image) ───────────────────────────────────
tests/

# ── Misc ─────────────────────────────────────────────────────────────────────
requirements.lock
*.log
logs/
