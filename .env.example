# ─────────────────────────────────────────────────────────
# AI Code Review Agent — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────

# ── LLM Provider (choose: "anthropic" or "openai") ───────
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI (GPT) ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── LLM Behaviour ────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.2
MAX_RETRIES=3
CHUNK_SIZE=3000

# ── GitHub Integration ───────────────────────────────────
# Create a token at: https://github.com/settings/tokens
# Requires: repo, read:org scopes for private repos
GITHUB_TOKEN=ghp_your_token_here

# ── Repository Cloning ───────────────────────────────────
CLONE_DIR=/tmp/ai_code_review_repos
MAX_FILE_SIZE_KB=500
MAX_FILES=50
CLONE_TIMEOUT=120

# ── Application ──────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
REPORTS_DIR=reports
MAX_PARALLEL_REVIEWS=5

# ── Cache ────────────────────────────────────────────────
CACHE_ENABLED=true

# ── Database ─────────────────────────────────────────────
# SQLite (default):
DATABASE_URL=sqlite:///reviews.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/code_review_db
